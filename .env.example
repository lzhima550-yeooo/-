# Backend (Node API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
API_PORT=8787
API_HOST=127.0.0.1
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=
SILICONFLOW_VISION_MODEL=Qwen/Qwen3-VL-32B-Instruct
SILICONFLOW_CHAT_MODEL=deepseek-ai/DeepSeek-V3
SILICONFLOW_TIMEOUT_MS=45000
COMFYUI_BASE_URL=http://127.0.0.1:8188
# Optional: public ComfyUI base URL used when COMFYUI_IMAGE_DELIVERY_MODE=direct
COMFYUI_PUBLIC_BASE_URL=
COMFYUI_CLIENT_ID=summer-wood-api
# Optional: if empty, backend will auto-pick first model from /models/checkpoints
COMFYUI_CHECKPOINT=
# Optional: defaults to ../comfyui/默认原始工作流.json
COMFYUI_WORKFLOW_PATH=
# Optional: JSON array, e.g.
# COMFYUI_WORKFLOW_PROFILES=[{"id":"default","label":"默认工作流","path":"D:/yeoooo/comfyui/默认原始工作流.json"}]
COMFYUI_WORKFLOW_PROFILES=
# Optional: routing rules (identify tags -> preset/workflow), JSON array, e.g.
# COMFYUI_WORKFLOW_ROUTING_RULES=[{"id":"pest","label":"虫害优先","priority":80,"typeLabels":["昆虫"],"matchKeywords":["蚜虫"],"presetId":"science_card","workflowId":"default"}]
COMFYUI_WORKFLOW_ROUTING_RULES=
COMFYUI_TIMEOUT_MS=120000
COMFYUI_POLL_INTERVAL_MS=1000
# Optional: proxy (recommended for mobile LAN) | direct
COMFYUI_IMAGE_DELIVERY_MODE=proxy
# Optional: backend proxy path for generated image URLs
COMFYUI_IMAGE_PROXY_PATH=/api/spirit/comfyui/view

# Frontend (Vite)
# Keep /api for local full-stack mode.
VITE_API_BASE_URL=/api
VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:8787
# Spirit identify (for future real API; default keeps offline ladybug demo)
# Values: backend | mock | remote
VITE_SPIRIT_IDENTIFY_MODE=backend
VITE_SPIRIT_IDENTIFY_ENDPOINT=
# Spirit chat
# Values: backend | mock
VITE_SPIRIT_CHAT_MODE=backend
# Identify page task mode
# Values: backend | mock
VITE_IDENTIFY_TASK_MODE=backend
